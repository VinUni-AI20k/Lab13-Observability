{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "additionalProperties:true — add new demo fields freely without breaking validation.",
  "type": "object",
  "required": ["ts", "level", "service", "event", "correlation_id"],
  "additionalProperties": true,
  "properties": {
    "ts":             { "type": "string" },
    "level":          { "type": "string" },
    "service":        { "type": "string" },
    "event":          { "type": "string" },
    "correlation_id": { "type": "string" },
    "env":            { "type": ["string", "null"] },
    "user_id_hash":   { "type": ["string", "null"] },
    "session_id":     { "type": ["string", "null"] },
    "feature":        { "type": ["string", "null"] },
    "model":          { "type": ["string", "null"] },
    "latency_ms":     { "type": ["integer", "null"] },
    "tokens_in":      { "type": ["integer", "null"] },
    "tokens_out":     { "type": ["integer", "null"] },
    "cost_usd":       { "type": ["number", "null"] },
    "error_type":     { "type": ["string", "null"] },
    "tool_name":      { "type": ["string", "null"] },
    "issue_type":     {
      "type": ["string", "null"],
      "enum": ["BUG", "FEATURE_REQUEST", "QUESTION", "UNKNOWN", null]
    },
    "model_used":     { "type": ["string", "null"] },
    "payload":        { "type": ["object", "null"] }
  }
}
