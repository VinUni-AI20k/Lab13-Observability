{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Day 13 Observability Lab — 6-Panel Dashboard for LLM Agent Monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Latency P50 / P95 / P99 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "description": "Tail latency percentiles. SLO: P95 < 3000ms.",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "latency_p50",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "expr": "latency_p95",
          "legendFormat": "P95"
        },
        {
          "refId": "C",
          "expr": "latency_p99",
          "legendFormat": "P99"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Traffic — Request Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "description": "Total requests processed since startup.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [{ "refId": "A", "expr": "traffic", "legendFormat": "Requests" }],
      "options": {
        "reduceOptions": { "calcs": ["last"] },
        "orientation": "auto",
        "textMode": "auto",
        "graphMode": "area",
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "description": "Error rate as % of total traffic. SLO: < 2%.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 20,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [{ "refId": "A", "expr": "error_rate_pct", "legendFormat": "Error Rate" }],
      "options": {
        "reduceOptions": { "calcs": ["last"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "title": "Cost Over Time (USD)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "description": "Cumulative cost and per-request average. SLO: < $2.50/day.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.0 },
              { "color": "red", "value": 2.5 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Avg Cost/Req" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "total_cost_usd", "legendFormat": "Total Cost" },
        { "refId": "B", "expr": "avg_cost_usd", "legendFormat": "Avg Cost/Req" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "title": "Tokens In / Out",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "description": "Total tokens consumed (input vs output). High input/output ratio signals verbose prompts.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 80 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Tokens In" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Tokens Out" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "tokens_in_total", "legendFormat": "Tokens In" },
        { "refId": "B", "expr": "tokens_out_total", "legendFormat": "Tokens Out" }
      ],
      "options": {
        "orientation": "vertical",
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Quality Score (Heuristic Average)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "description": "Average heuristic quality score (0–1). SLO: ≥ 0.75. Red below 0.6.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.75 }
            ]
          }
        }
      },
      "targets": [{ "refId": "A", "expr": "quality_avg", "legendFormat": "Quality Score" }],
      "options": {
        "reduceOptions": { "calcs": ["last"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": {}
      }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["observability", "llm", "lab13"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Day 13 — LLM Agent Observability Dashboard",
  "uid": "lab13-observability",
  "version": 1
}
